# Public, non-secret deployment defaults for the static okhlopkov.com app.
# Copy to `.env` on a VPS only if you run docker compose manually.

SITE_URL=https://okhlopkov.com
VITE_SITE_URL=https://okhlopkov.com

# Keep the container private behind Caddy/Nginx/Cloudflare Tunnel unless you
# intentionally expose it directly.
OKHLOPKOV_BIND=127.0.0.1
OKHLOPKOV_PORT=8080
